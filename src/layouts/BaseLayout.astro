---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Krallice — European Tour 2026',
  description = 'Krallice on tour in Europe, October–November 2026. Dates and tickets.',
} = Astro.props;

const ogImage = new URL('/krallicelogo.png', Astro.site ?? 'https://krallicetour.com').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body class="min-h-screen font-sans text-stone-100 antialiased">
    <slot />
  </body>
</html>
