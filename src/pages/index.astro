---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTourDates } from '../data/tour';

const dates = getTourDates();
---

<BaseLayout>
  <div class="min-h-screen bg-black/65">
    <main class="mx-auto max-w-3xl px-6 py-8 md:py-16">
      <header class="flex flex-col items-center text-center">
        <img
          src="/krallicelogo.png"
          alt="Krallice"
          class="w-full max-w-md md:max-w-lg drop-shadow-[0_0_30px_rgba(0,0,0,0.8)]"
        />
        <h1 class="md:mt-10 mt-6 font-display text-2xl md:text-4xl uppercase tracking-[0.4em] text-stone-200">
          European Tour
        </h1>
        <p class="mt-3 text-xs md:text-sm uppercase tracking-[0.5em] text-stone-400">
          October — November 2026
        </p>
      </header>

      <section class="mt-12 md:mt-16">
        <ul class="divide-y divide-stone-700/60 border-y border-stone-700/60">
          {dates.map((d) => (
            <li class="grid grid-cols-[5rem_1fr_auto] items-center gap-4 md:gap-8 py-5">
              <time datetime={d.iso} class="font-mono tabular-nums leading-tight">
                <span class="block text-[0.65rem] uppercase tracking-widest text-stone-500">
                  {d.weekday}
                </span>
                <span class="text-base md:text-lg text-stone-200">{d.dateLabel}</span>
              </time>

              <div class="min-w-0">
                <p class="font-display text-lg md:text-xl text-stone-100 leading-tight">
                  {d.city}<span class="text-stone-500">, {d.country}</span>
                </p>
                <p class="text-sm text-stone-400 truncate">{d.venue}</p>
              </div>

              <div class="relative inline-block">
                <span class="block border border-stone-700 px-3 md:px-5 py-2 text-[0.7rem] md:text-xs uppercase tracking-[0.2em] text-stone-500">
                  Tickets
                </span>
                <span class="absolute -top-2 -right-2 bg-stone-100 text-black text-[0.55rem] md:text-[0.6rem] uppercase tracking-[0.1em] px-1.5 py-0.5 whitespace-nowrap">
                  On sale May 26
                </span>
              </div>
            </li>
          ))}
        </ul>
      </section>

      <footer class="mt-16 flex flex-col items-center gap-2 text-center text-[0.7rem] uppercase tracking-[0.3em] text-stone-500">
        <a href="https://krallice.bandcamp.com" target="_blank" rel="noopener noreferrer" class="hover:text-stone-300 transition-colors">
          krallice.bandcamp.com
        </a>
      </footer>
    </main>
  </div>
</BaseLayout>
